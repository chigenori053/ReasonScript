{
  "schema_version": "reason-ir/0.1",
  "initial_state": {
    "state_id": "UnverifiedClaim",
    "state_type": "claim",
    "data": {
      "confidence": 0.2
    }
  },
  "goal": {
    "kind": "evaluate",
    "target": "Rejected"
  },
  "constraints": [
    {
      "constraint_id": "minimum-confidence",
      "kind": "semantic",
      "expression": "confidence >= 0.8"
