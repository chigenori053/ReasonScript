  "transitions": [
    {
      "transition_id": "reject-low-confidence",
      "source": "UnverifiedClaim",
      "relation": "Reject",
      "target": "Rejected",
      "expected_cost": 0
    }
  ],
  "execution_policy": {
    "max_steps": 4,
    "rollback_on_failure": true,
    "constraint_mode": "reject"
  },
  "trace_policy": {
