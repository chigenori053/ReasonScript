{
  "name": "reasonscript",
  "displayName": "ReasonScript",
  "description": "Official ReasonScript editor integration.",
  "version": "0.1.7",
  "publisher": "reasonscript",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chigenori053/ReasonScript.git"
  },
  "homepage": "https://github.com/chigenori053/ReasonScript#readme",
  "bugs": {
    "url": "https://github.com/chigenori053/ReasonScript/issues"
  },
  "keywords": [
    "reasonscript",
    "reasoning",
    "language"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:reasonscript",
    "workspaceContains:reason.toml",
    "workspaceContains:reason.workspace.toml",
    "onCommand:reasonscript.build",
    "onCommand:reasonscript.run",
    "onCommand:reasonscript.test",
    "onCommand:reasonscript.check"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "reasonscript",
        "aliases": [
          "ReasonScript",
          "reasonscript"
        ],
        "extensions": [
          ".rsn"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "reasonscript",
        "scopeName": "source.reasonscript",
        "path": "./syntaxes/reasonscript.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "reasonscript.build",
        "title": "ReasonScript: Build"
      },
      {
        "command": "reasonscript.run",
        "title": "ReasonScript: Run"
      },
      {
        "command": "reasonscript.test",
        "title": "ReasonScript: Test"
      },
      {
        "command": "reasonscript.check",
        "title": "ReasonScript: Check"
      }
    ],
    "configuration": {
      "title": "ReasonScript",
      "properties": {
        "reasonscript.autoCheck": {
          "type": "boolean",
          "default": true,
          "description": "Run reason check automatically for workspace diagnostics."
        },
        "reasonscript.showTrace": {
          "type": "boolean",
          "default": false,
          "description": "Expose raw ReasoningTrace JSON in output channels when available."
        },
        "reasonscript.defaultCommand": {
          "type": "string",
          "enum": [
            "build",
            "run",
            "test",
            "check"
          ],
          "default": "run",
          "description": "Default ReasonScript command used by editor integrations."
        },
        "reasonscript.executablePath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the `reason` executable. Leave empty to auto-detect from workspace or PATH."
        }
      }
    },
    "taskDefinitions": [
      {
        "type": "reasonscript",
        "required": [
          "command"
        ],
        "properties": {
          "command": {
            "type": "string"
          },
          "package": {
            "type": "string"
          }
        }
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "package": "vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.15.0"
  }
}
