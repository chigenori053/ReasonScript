{
  "schema_version": "reason-ir/0.1",
  "initial_state": {"state_id": "PlanStart", "state_type": "dbm", "data": {"budget": 10}},
  "goal": {"kind": "reach_state", "target": "PlanComplete"},
  "transitions": [
    {"transition_id": "select-plan", "source": "PlanStart", "relation": "Plan", "target": "PlanComplete", "expected_cost": 1.0}
  ],
  "execution_policy": {"max_steps": 128, "rollback_on_failure": true, "constraint_mode": "reject"},
  "trace_policy": {"level": "standard", "include_alternatives": true, "include_state_data": true},
  "planner_policy": {"strategy": "minimum_expected_cost", "max_depth": 128, "max_alternatives": 8},
  "constraints": [
    {"constraint_id": "within-budget", "kind": "numeric", "expression": "budget >= 5"}
  ]
}
