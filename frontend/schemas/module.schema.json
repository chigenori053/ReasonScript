{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reasonscript.org/schema/ast/module/0.1",
  "title": "ModuleNode",
  "type": "object",
  "additionalProperties": false,
  "required": ["node_type", "version", "node_id", "declarations"],
  "properties": {
    "node_type": {"const": "ModuleNode"},
    "version": {"const": "reasonscript-ast/0.1"},
    "node_id": {"type": "string", "minLength": 1},
    "imports": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "default": []
    },
    "declarations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {"$ref": "goal.schema.json"},
          {"$ref": "state.schema.json"},
          {"$ref": "transition.schema.json"},
          {"$ref": "constraint.schema.json"},
          {"$ref": "context.schema.json"}
        ]
      }
    },
    "metadata": {
      "type": "array",
      "items": {"$ref": "metadata.schema.json"},
      "default": []
    }
  }
}
