{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StateNode",
  "type": "object",
  "additionalProperties": false,
  "required": ["node_type", "node_id", "state_id", "state_type", "data"],
  "properties": {
    "node_type": {"const": "StateNode"},
    "node_id": {"type": "string", "minLength": 1},
    "state_id": {"type": "string", "minLength": 1},
    "state_type": {"type": "string", "minLength": 1},
    "data": true
  }
}
