{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reasonscript.org/schema/language-surface-ast/0.1",
  "title": "ReasonScript Language Surface AST 0.1",
  "$ref": "#/$defs/program",
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1
    },
    "qualified_identifier_string": {
      "type": "string",
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*(\\.[A-Za-z_][A-Za-z0-9_]*)*$"
    },
    "type_node": {
      "oneOf": [
        {"$ref": "#/$defs/primitive_type"},
        {"$ref": "#/$defs/state_type"},
        {"$ref": "#/$defs/named_type"},
        {"$ref": "#/$defs/array_type"},
        {"$ref": "#/$defs/tuple_type"},
        {"$ref": "#/$defs/set_type"},
        {"$ref": "#/$defs/map_type"},
        {"$ref": "#/$defs/optional_type"}
      ]
    },
    "primitive_type": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "node_type"],
      "properties": {
        "kind": {"enum": ["Int", "Float", "Bool", "String", "Null"]},
        "node_type": {"const": "PrimitiveTypeNode"}
      }
    },
    "state_type": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "node_type"],
      "properties": {
        "kind": {
          "enum": [
            "Concept",
            "Object",
            "Event",
            "Action",
            "Attribute",
            "Goal",
            "Constraint"
          ]
        },
        "node_type": {"const": "StateTypeNode"}
      }
    },
    "named_type": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "node_type"],
      "properties": {
        "name": {"$ref": "#/$defs/identifier"},
        "node_type": {"const": "NamedTypeNode"}
      }
    },
    "array_type": {
      "type": "object",
      "additionalProperties": false,
      "required": ["element_type", "node_type"],
      "properties": {
        "element_type": {"$ref": "#/$defs/type_node"},
        "node_type": {"const": "ArrayTypeNode"}
      }
    },
    "tuple_type": {
      "type": "object",
      "additionalProperties": false,
      "required": ["element_types", "node_type"],
      "properties": {
        "element_types": {
          "type": "array",
          "items": {"$ref": "#/$defs/type_node"}
        },
        "node_type": {"const": "TupleTypeNode"}
      }
    },
    "set_type": {
      "type": "object",
      "additionalProperties": false,
      "required": ["element_type", "node_type"],
      "properties": {
        "element_type": {"$ref": "#/$defs/type_node"},
        "node_type": {"const": "SetTypeNode"}
      }
    },
    "map_type": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key_type", "value_type", "node_type"],
      "properties": {
        "key_type": {"$ref": "#/$defs/type_node"},
        "value_type": {"$ref": "#/$defs/type_node"},
        "node_type": {"const": "MapTypeNode"}
      }
    },
    "optional_type": {
      "type": "object",
      "additionalProperties": false,
      "required": ["inner_type", "node_type"],
      "properties": {
        "inner_type": {"$ref": "#/$defs/type_node"},
        "node_type": {"const": "OptionalTypeNode"}
      }
    },
    "expression": {
      "type": "object",
      "additionalProperties": false,
      "required": ["expression", "node_type"],
      "properties": {
        "expression": {"$ref": "#/$defs/expression_value"},
        "node_type": {"const": "ExpressionNode"}
      }
    },
    "expression_value": {
      "oneOf": [
        {"$ref": "#/$defs/integer_literal"},
        {"$ref": "#/$defs/float_literal"},
        {"$ref": "#/$defs/boolean_literal"},
        {"$ref": "#/$defs/string_literal"},
        {"$ref": "#/$defs/null_literal"},
        {"$ref": "#/$defs/none_literal"},
        {"$ref": "#/$defs/some_expression"},
        {"$ref": "#/$defs/identifier_expression"},
        {"$ref": "#/$defs/qualified_identifier"},
        {"$ref": "#/$defs/runtime_namespace"},
        {"$ref": "#/$defs/runtime_call_expression"},
        {"$ref": "#/$defs/unary_expression"},
        {"$ref": "#/$defs/binary_expression"},
        {"$ref": "#/$defs/comparison_expression"},
        {"$ref": "#/$defs/logical_expression"},
        {"$ref": "#/$defs/parenthesized_expression"},
        {"$ref": "#/$defs/member_access"},
        {"$ref": "#/$defs/call_expression"},
        {"$ref": "#/$defs/struct_literal"},
        {"$ref": "#/$defs/array_literal"},
        {"$ref": "#/$defs/tuple_literal"},
        {"$ref": "#/$defs/set_literal"},
        {"$ref": "#/$defs/map_literal"},
        {"$ref": "#/$defs/index_access"}
      ]
    },
    "integer_literal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "node_type"],
      "properties": {
        "value": {"type": "integer"},
        "node_type": {"const": "IntegerLiteralNode"}
      }
    },
    "float_literal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "node_type"],
      "properties": {
        "value": {"type": "number"},
        "node_type": {"const": "FloatLiteralNode"}
      }
    },
    "boolean_literal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "node_type"],
      "properties": {
        "value": {"type": "boolean"},
        "node_type": {"const": "BooleanLiteralNode"}
      }
    },
    "string_literal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "node_type"],
      "properties": {
        "value": {"type": "string"},
        "node_type": {"const": "StringLiteralNode"}
      }
    },
    "null_literal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node_type"],
      "properties": {
        "node_type": {"const": "NullLiteralNode"}
      }
    },
    "none_literal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node_type"],
      "properties": {
        "node_type": {"const": "NoneLiteralNode"}
      }
    },
    "some_expression": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "node_type"],
      "properties": {
        "value": {"$ref": "#/$defs/expression_value"},
        "node_type": {"const": "SomeExpressionNode"}
      }
    },
    "identifier_expression": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "node_type"],
      "properties": {
        "name": {"$ref": "#/$defs/identifier"},
        "node_type": {"const": "IdentifierNode"}
      }
    },
    "qualified_identifier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "symbol", "resolved_name", "node_type"],
      "properties": {
        "path": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/identifier"}
        },
        "symbol": {"$ref": "#/$defs/identifier"},
        "resolved_name": {"type": ["string", "null"]},
        "node_type": {"const": "QualifiedIdentifierNode"}
      }
    },
    "runtime_namespace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "node_type"],
      "properties": {
        "name": {"const": "runtime"},
        "node_type": {"const": "RuntimeNamespaceNode"}
      }
    },
    "runtime_call_expression": {
      "type": "object",
      "additionalProperties": false,
      "required": ["namespace", "method", "kind", "arguments", "node_type"],
      "properties": {
        "namespace": {"$ref": "#/$defs/runtime_namespace"},
        "method": {"enum": ["input", "print", "search", "simulate", "predict", "plan"]},
        "kind": {
          "enum": [
            "InputCall",
            "PrintCall",
            "SearchCall",
            "SimulationCall",
            "PredictionCall",
            "PlanningCall"
          ]
        },
        "arguments": {
          "type": "array",
          "minItems": 0,
          "maxItems": 1,
          "items": {"$ref": "#/$defs/expression_value"}
        },
        "node_type": {"const": "RuntimeCallExpressionNode"}
      }
    },
    "unary_expression": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operator", "operand", "node_type"],
      "properties": {
        "operator": {"enum": ["Negate", "Not"]},
        "operand": {"$ref": "#/$defs/expression_value"},
        "node_type": {"const": "UnaryExpressionNode"}
      }
    },
    "binary_expression": {
      "type": "object",
      "additionalProperties": false,
      "required": ["left", "operator", "right", "node_type"],
      "properties": {
        "left": {"$ref": "#/$defs/expression_value"},
        "operator": {
          "enum": ["Add", "Subtract", "Multiply", "Divide", "Modulo"]
        },
        "right": {"$ref": "#/$defs/expression_value"},
        "node_type": {"const": "BinaryExpressionNode"}
      }
    },
    "comparison_expression": {
      "type": "object",
      "additionalProperties": false,
      "required": ["left", "operator", "right", "node_type"],
      "properties": {
        "left": {"$ref": "#/$defs/expression_value"},
        "operator": {
          "enum": [
            "Equal",
            "NotEqual",
            "GreaterThan",
            "GreaterThanOrEqual",
            "LessThan",
            "LessThanOrEqual"
          ]
        },
        "right": {"$ref": "#/$defs/expression_value"},
        "node_type": {"const": "ComparisonExpressionNode"}
      }
    },
    "logical_expression": {
      "type": "object",
      "additionalProperties": false,
      "required": ["left", "operator", "right", "node_type"],
      "properties": {
        "left": {"$ref": "#/$defs/expression_value"},
        "operator": {"enum": ["And", "Or"]},
        "right": {"$ref": "#/$defs/expression_value"},
        "node_type": {"const": "LogicalExpressionNode"}
      }
    },
    "parenthesized_expression": {
      "type": "object",
      "additionalProperties": false,
      "required": ["expression", "node_type"],
      "properties": {
        "expression": {"$ref": "#/$defs/expression_value"},
        "node_type": {"const": "ParenthesizedExpressionNode"}
      }
    },
    "member_access": {
      "type": "object",
      "additionalProperties": false,
      "required": ["object", "member", "node_type"],
      "properties": {
        "object": {"$ref": "#/$defs/expression_value"},
        "member": {"$ref": "#/$defs/identifier"},
        "node_type": {"const": "MemberAccessNode"}
      }
    },
    "call_expression": {
      "type": "object",
      "additionalProperties": false,
      "required": ["callee", "arguments", "node_type"],
      "properties": {
        "callee": {"$ref": "#/$defs/expression_value"},
        "arguments": {
          "type": "array",
          "items": {"$ref": "#/$defs/expression_value"}
        },
        "node_type": {"const": "CallExpressionNode"}
      }
    },
    "struct_literal_field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field_name", "expression", "node_type"],
      "properties": {
        "field_name": {"$ref": "#/$defs/identifier"},
        "expression": {"$ref": "#/$defs/expression"},
        "node_type": {"const": "StructLiteralFieldNode"}
      }
    },
    "struct_literal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type_name", "fields", "node_type"],
      "properties": {
        "type_name": {"$ref": "#/$defs/qualified_identifier_string"},
        "fields": {
          "type": "array",
          "items": {"$ref": "#/$defs/struct_literal_field"}
        },
        "node_type": {"const": "StructLiteralExpressionNode"}
      }
    },
    "array_literal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["elements", "node_type"],
      "properties": {
        "elements": {
          "type": "array",
          "items": {"$ref": "#/$defs/expression"}
        },
        "node_type": {"const": "ArrayLiteralNode"}
      }
    },
    "tuple_literal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["elements", "node_type"],
      "properties": {
        "elements": {
          "type": "array",
          "items": {"$ref": "#/$defs/expression"}
        },
        "node_type": {"const": "TupleLiteralNode"}
      }
    },
    "set_literal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["elements", "node_type"],
      "properties": {
        "elements": {
          "type": "array",
          "items": {"$ref": "#/$defs/expression"}
        },
        "node_type": {"const": "SetLiteralNode"}
      }
    },
    "map_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "value", "node_type"],
      "properties": {
        "key": {"$ref": "#/$defs/expression"},
        "value": {"$ref": "#/$defs/expression"},
        "node_type": {"const": "MapEntryNode"}
      }
    },
    "map_literal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entries", "node_type"],
      "properties": {
        "entries": {
          "type": "array",
          "items": {"$ref": "#/$defs/map_entry"}
        },
        "node_type": {"const": "MapLiteralNode"}
      }
    },
    "index_access": {
      "type": "object",
      "additionalProperties": false,
      "required": ["collection", "index", "node_type"],
      "properties": {
        "collection": {"$ref": "#/$defs/expression_value"},
        "index": {"$ref": "#/$defs/expression_value"},
        "node_type": {"const": "IndexAccessNode"}
      }
    },
    "pattern": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pattern", "node_type"],
      "properties": {
        "pattern": {"$ref": "#/$defs/pattern_value"},
        "node_type": {"const": "PatternNode"}
      }
    },
    "pattern_value": {
      "oneOf": [
        {"$ref": "#/$defs/identifier_pattern"},
        {"$ref": "#/$defs/qualified_pattern"},
        {"$ref": "#/$defs/wildcard_pattern"},
        {"$ref": "#/$defs/default_pattern"},
        {"$ref": "#/$defs/literal_pattern"},
        {"$ref": "#/$defs/enum_value_pattern"},
        {"$ref": "#/$defs/optional_pattern"},
        {"$ref": "#/$defs/struct_pattern"}
      ]
    },
    "identifier_pattern": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "node_type"],
      "properties": {
        "name": {"$ref": "#/$defs/identifier"},
        "node_type": {"const": "IdentifierPatternNode"}
      }
    },
    "qualified_pattern": {
      "type": "object",
      "additionalProperties": false,
      "required": ["namespace", "identifier", "node_type"],
      "properties": {
        "namespace": {"$ref": "#/$defs/identifier"},
        "identifier": {"$ref": "#/$defs/identifier"},
        "node_type": {"const": "QualifiedPatternNode"}
      }
    },
    "wildcard_pattern": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node_type"],
      "properties": {
        "node_type": {"const": "WildcardPatternNode"}
      }
    },
    "default_pattern": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node_type"],
      "properties": {
        "node_type": {"const": "DefaultPatternNode"}
      }
    },
    "literal_pattern": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "node_type"],
      "properties": {
        "value": {
          "oneOf": [
            {"$ref": "#/$defs/integer_literal"},
            {"$ref": "#/$defs/float_literal"},
            {"$ref": "#/$defs/boolean_literal"},
            {"$ref": "#/$defs/string_literal"},
            {"$ref": "#/$defs/null_literal"}
          ]
        },
        "node_type": {"const": "LiteralPatternNode"}
      }
    },
    "enum_value_pattern": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enum_name", "value_name", "node_type"],
      "properties": {
        "enum_name": {"$ref": "#/$defs/identifier"},
        "value_name": {"$ref": "#/$defs/identifier"},
        "node_type": {"const": "EnumValuePatternNode"}
      }
    },
    "optional_pattern": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "binding", "node_type"],
      "properties": {
        "kind": {"enum": ["Some", "None"]},
        "binding": {
          "oneOf": [
            {"$ref": "#/$defs/identifier"},
            {"type": "null"}
          ]
        },
        "node_type": {"const": "OptionalPatternNode"}
      }
    },
    "struct_pattern": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type_name", "fields", "node_type"],
      "properties": {
        "type_name": {"type": "string", "minLength": 1},
        "fields": {
          "type": "array",
          "items": {"$ref": "#/$defs/struct_field_pattern"}
        },
        "node_type": {"const": "StructPatternNode"}
      }
    },
    "struct_field_pattern": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field_name", "pattern", "node_type"],
      "properties": {
        "field_name": {"$ref": "#/$defs/identifier"},
        "pattern": {
          "$comment": "LSI-204A: field patterns are recursive and may be StructPatternNode.",
          "$ref": "#/$defs/pattern_value"
        },
        "node_type": {"const": "StructFieldPatternNode"}
      }
    },
    "program": {
      "type": "object",
      "additionalProperties": false,
      "required": ["modules", "package", "node_type"],
      "properties": {
        "modules": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/module"}
        },
        "package": {
          "oneOf": [
            {"$ref": "#/$defs/package_declaration"},
            {"type": "null"}
          ]
        },
        "node_type": {"const": "ProgramNode"}
      }
    },
    "package_declaration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "node_type"],
      "properties": {
        "name": {"$ref": "#/$defs/identifier"},
        "node_type": {"const": "PackageDeclarationNode"}
      }
    },
    "module": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "visibility", "body", "node_type"],
      "properties": {
        "name": {"$ref": "#/$defs/identifier"},
        "visibility": {"enum": ["Public", "Private"]},
        "body": {
          "type": "array",
          "items": {"$ref": "#/$defs/ast_node"}
        },
        "node_type": {"const": "ModuleNode"}
      }
    },
    "ast_node": {
      "oneOf": [
        {"$ref": "#/$defs/import"},
        {"$ref": "#/$defs/named_declaration"},
        {"$ref": "#/$defs/goal_declaration"},
        {"$ref": "#/$defs/constraint_declaration"},
        {"$ref": "#/$defs/state_declaration"},
        {"$ref": "#/$defs/reason_graph_declaration"},
        {"$ref": "#/$defs/execution_plan_declaration"},
        {"$ref": "#/$defs/relation"},
        {"$ref": "#/$defs/transition"},
        {"$ref": "#/$defs/calculation"},
        {"$ref": "#/$defs/function_declaration"},
        {"$ref": "#/$defs/struct_declaration"},
        {"$ref": "#/$defs/enum_declaration"},
        {"$ref": "#/$defs/const_declaration"}
      ]
    },
    "statement": {
      "oneOf": [
        {"$ref": "#/$defs/let"},
        {"$ref": "#/$defs/const_statement"},
        {"$ref": "#/$defs/assignment"},
        {"$ref": "#/$defs/field_assignment"},
        {"$ref": "#/$defs/index_assignment"},
        {"$ref": "#/$defs/result_statement"},
        {"$ref": "#/$defs/return_statement"},
        {"$ref": "#/$defs/require_statement"},
        {"$ref": "#/$defs/goal_statement"},
        {"$ref": "#/$defs/reach_statement"},
        {"$ref": "#/$defs/expression_statement"},
        {"$ref": "#/$defs/for_statement"},
        {"$ref": "#/$defs/while_statement"},
        {"$ref": "#/$defs/loop_statement"},
        {"$ref": "#/$defs/break_statement"},
        {"$ref": "#/$defs/continue_statement"},
        {"$ref": "#/$defs/if"},
        {"$ref": "#/$defs/match"}
      ]
    },
    "import": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "alias", "resolution", "node_type"],
      "properties": {
        "path": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/identifier"}
        },
        "alias": {
          "type": ["string", "null"]
        },
        "resolution": {
          "oneOf": [
            {"$ref": "#/$defs/import_resolution"},
            {"type": "null"}
          ]
        },
        "node_type": {"const": "ImportNode"}
      }
    },
    "import_resolution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "namespace",
        "symbol",
        "exposed_names",
        "node_type"
      ],
      "properties": {
        "namespace": {"type": "string", "minLength": 1},
        "symbol": {"type": ["string", "null"]},
        "exposed_names": {
          "type": "array",
          "items": {"$ref": "#/$defs/identifier"}
        },
        "node_type": {"const": "ImportResolutionNode"}
      }
    },
    "named_declaration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "node_type"],
      "properties": {
        "name": {"$ref": "#/$defs/identifier"},
        "node_type": {
          "enum": [
            "ConceptNode",
            "ObjectNode",
            "EventNode",
            "ActionNode",
            "AttributeNode"
          ]
        }
      }
    },
    "goal_declaration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "metadata", "node_type"],
      "properties": {
        "name": {"$ref": "#/$defs/identifier"},
        "metadata": {"type": "array"},
        "node_type": {"const": "GoalNode"}
      }
    },
    "constraint_declaration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "expression", "node_type"],
      "properties": {
        "name": {"$ref": "#/$defs/identifier"},
        "expression": {"type": ["string", "null"]},
        "node_type": {"const": "ConstraintNode"}
      }
    },
    "state_declaration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "metadata", "node_type"],
      "properties": {
        "name": {"$ref": "#/$defs/identifier"},
        "metadata": {"type": "array"},
        "node_type": {"const": "StateDeclarationNode"}
      }
    },
    "reason_graph_transition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "target", "node_type"],
      "properties": {
        "source": {"$ref": "#/$defs/identifier"},
        "target": {"$ref": "#/$defs/identifier"},
        "node_type": {"const": "ReasonGraphTransitionNode"}
      }
    },
    "reason_graph_declaration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "states", "transitions", "node_type"],
      "properties": {
        "name": {"$ref": "#/$defs/identifier"},
        "states": {
          "type": "array",
          "items": {"$ref": "#/$defs/state_declaration"}
        },
        "transitions": {
          "type": "array",
          "items": {"$ref": "#/$defs/reason_graph_transition"}
        },
        "node_type": {"const": "ReasonGraphDeclarationNode"}
      }
    },
    "plan_step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "target", "node_type"],
      "properties": {
        "source": {"$ref": "#/$defs/identifier"},
        "target": {"$ref": "#/$defs/identifier"},
        "node_type": {"const": "PlanStepNode"}
      }
    },
