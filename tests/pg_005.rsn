module Test {
    struct Position {
        x: int
        y: int
    }

    struct Person {
        position: Position
    }

    fn Score(person: Person) -> int {
        match person {
            Person { position: Position { x, y } } when x > y => return 1
            Person { } => return 0
        }
    }

    calculation Result {
        result = Score(Person { position: Position { x: 10, y: 5 } })
    }
}
