module Test {
    struct Point {
        x: int
        y: int
    }

    fn Score(point: Point) -> int {
        match point {
            Point { x: 0, y: 0 } => return 100
            default => return 0
        }
    }

    calculation Result {
        result = Score(Point { x: 1, y: 2 })
    }
}
